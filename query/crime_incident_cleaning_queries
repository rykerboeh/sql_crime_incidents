-- ======================================
-- Creating Clean Crime Incidents View
-- ======================================

-- This compounding CTE query combines the logic from the above cleaning queries to construct a data view of the cleaned data

CREATE VIEW clean_crime_incidents AS
WITH base AS (
    SELECT *
    FROM crime_incidents
),

-- Clean Date
clean_date AS (
    SELECT *,
        CASE
            WHEN TRIM(incident_datetime) ~ '^\d{1,2}/\d{1,2}/\d{2} \d{1,2}:\d{2}$'
                THEN TO_TIMESTAMP(TRIM(incident_datetime), 'MM/DD/YY HH24:MI')

            WHEN TRIM(incident_datetime) ~ '^\d{1,2}/\d{1,2}/\d{2}$'
                THEN TO_TIMESTAMP(TRIM(incident_datetime) || ' 00:00', 'MM/DD/YY HH24:MI')

            WHEN TRIM(incident_datetime) ~ '^\d{2}-\d{2}-\d{4}$'
                THEN TO_TIMESTAMP(TRIM(incident_datetime) || ' 00:00', 'DD-MM-YYYY HH24:MI')

            ELSE NULL
        END AS std_incident_timestamp
    FROM base
),

-- Property Loss
clean_prop_loss AS (
    SELECT *,
        CASE
            WHEN property_loss_usd IS NULL THEN 0
            ELSE ROUND(
                ABS(
                    REPLACE(
                        REGEXP_REPLACE(
                            REGEXP_REPLACE(property_loss_usd, '\.', '#'),
                            '\.', '', 'g'
                        ),
                        '#', '.'
                    )::numeric
                ),
                2
            )
        END AS std_property_loss_usd
    FROM clean_date
),

-- Ages
clean_ages AS (
    SELECT *,
        CASE
            WHEN suspect_age < 0 THEN ABS(suspect_age)
            WHEN suspect_age > 110 THEN LEFT(suspect_age::text, LENGTH(suspect_age::text) - 1)::INT
            ELSE suspect_age
        END AS std_suspect_age,

        CASE
            WHEN victim_age < 0 THEN ABS(victim_age)
            WHEN victim_age > 110 THEN LEFT(victim_age::text, LENGTH(victim_age::text) - 1)::INT
            ELSE victim_age
        END AS std_victim_age
    FROM clean_prop_loss
),

-- Arrests
clean_arrests AS (
    SELECT *,
        CASE
            WHEN num_arrests IS NULL THEN 0
            WHEN num_arrests < 0 THEN ABS(num_arrests)
            ELSE num_arrests
        END AS std_num_arrests
    FROM clean_ages
),

-- Phone
clean_phone AS (
    SELECT *,
        REGEXP_REPLACE(NULLIF(victim_phone, 'N/A'), '[^0-9]', '', 'g') AS std_victim_phone
    FROM clean_arrests
),

-- Crime Type
clean_crime_type AS (
    SELECT *,
        COALESCE(m.std_value, c.crime_type) AS std_crime_type
    FROM clean_phone c
    LEFT JOIN crime_type_map m
        ON REPLACE(REPLACE(REPLACE(TRIM(LOWER(c.crime_type)), ' ', '<>'), '><', ''), '<>', ' ') = m.raw_value
),

-- District
clean_district AS (
    SELECT *,
        COALESCE(m.std_value, c.district) AS std_district
    FROM clean_crime_type c
    LEFT JOIN district_map m
        ON TRIM(LOWER(c.district)) = m.raw_value
),

-- Gender
clean_gender AS (
    SELECT *,
        COALESCE(ms.std_value, 'n/a') AS std_suspect_gender,
        COALESCE(mv.std_value, 'n/a') AS std_victim_gender
    FROM clean_district c
    LEFT JOIN gender_map ms
        ON TRIM(LOWER(c.suspect_gender)) = ms.raw_value
    LEFT JOIN gender_map mv
        ON TRIM(LOWER(c.victim_gender)) = mv.raw_value
),

-- Race
clean_race AS (
    SELECT *,
        CASE
            WHEN suspect_race IS NULL OR TRIM(LOWER(suspect_race)) = 'unknown'
                THEN 'n/a'
            ELSE TRIM(LOWER(suspect_race))
        END AS std_suspect_race
    FROM clean_gender
),

-- Weapon
clean_weapon AS (
    SELECT *,
        COALESCE(m.std_value, 'none') AS std_weapon_used
    FROM clean_race c
    LEFT JOIN weapon_map m
        ON TRIM(LOWER(c.weapon_used)) = m.raw_value
),

-- Severity
clean_severity AS (
    SELECT *,
        COALESCE(m.std_value, 'low') AS std_severity
    FROM clean_weapon c
    LEFT JOIN severity_map m
        ON TRIM(LOWER(c.severity)) = m.raw_value
),

-- Resolution + Case Status
clean_case AS (
    SELECT *,
        COALESCE(csm.std_value, c.case_status, 'n/a') AS std_case_status,
        COALESCE(rm.std_value, c.resolution) AS std_resolution
    FROM clean_severity c
    LEFT JOIN resolution_map rm
        ON TRIM(LOWER(c.resolution)) = rm.raw_value
    LEFT JOIN case_status_map csm
        ON TRIM(LOWER(c.case_status)) = csm.raw_value
),

final_case AS (
    SELECT *,
        CASE
            WHEN std_resolution = 'dismissed' THEN 'closed'
            ELSE std_case_status
        END AS final_case_status
    FROM clean_case
),

-- Reported Online
clean_reported_online AS (
    SELECT *,
        COALESCE(m.std_value, FALSE) AS std_reported_online
    FROM final_case c
    LEFT JOIN reported_online_map m
        ON TRIM(LOWER(c.reported_online)) = m.raw_value
),

-- Names
clean_names AS (
	SELECT *,
		TRIM(INITCAP(officer_first_name)) AS std_officer_first_name,
		TRIM(INITCAP(officer_last_name)) AS std_officer_last_name,
		TRIM(INITCAP(suspect_first_name)) AS std_suspect_first_name,
		TRIM(INITCAP(suspect_last_name)) AS std_suspect_last_name,
		TRIM(INITCAP(victim_first_name)) AS std_victim_first_name,
		TRIM(INITCAP(victim_last_name)) AS std_victim_last_name
FROM clean_reported_online
)

-- Final Output
SELECT
	incident_id,
	std_crime_type,
	std_district,
	city,
	state,
	address,
	latitude,
	longitude,
    std_incident_timestamp,
	officer_id,
	std_officer_first_name,
	std_officer_last_name,
	badge_number,
	suspect_id,
	std_suspect_first_name,
	std_suspect_last_name,
	std_suspect_age,
	std_suspect_gender,
	std_suspect_race,
	victim_id,
	std_victim_first_name,
	std_victim_last_name,
	std_victim_age,
	std_victim_gender,
	std_victim_phone,
	std_weapon_used,
	std_severity,
	final_case_status,
	std_resolution,
	std_num_arrests,
    std_property_loss_usd,
    std_reported_online
FROM clean_names;

-- =================================
-- Creating Crime Analysis View
-- =================================

-- Set clean columns to their original names and construct view of only cleaned data for increased analytical efficiency and accuracy
CREATE VIEW crime_analysis AS 
(
SELECT
	incident_id,
	std_crime_type AS crime_type,
	std_district AS district,
	city,
	state,
	address,
	latitude,
	longitude,
    std_incident_timestamp AS incident_timestamp,
	officer_id,
	std_officer_first_name AS officer_first_name,
	std_officer_last_name AS officer_last_name,
	badge_number,
	suspect_id,
	std_suspect_first_name AS suspect_first_name,
	std_suspect_last_name AS suspect_last_name,
	std_suspect_age AS suspect_age,
	std_suspect_gender AS suspect_gender,
	std_suspect_race AS suspect_race,
	victim_id,
	std_victim_first_name AS victim_first_name,
	std_victim_last_name AS victim_last_name,
	std_victim_age AS victim_age,
	std_victim_gender AS victim_gender,
	std_victim_phone AS victim_phone,
	std_weapon_used AS weapon_used,
	std_severity AS severity,
	final_case_status AS case_status,
	std_resolution AS resolution,
	std_num_arrests AS num_arrests,
    std_property_loss_usd AS property_loss_usd,
    std_reported_online AS reported_online
FROM clean_crime_incidents
);

