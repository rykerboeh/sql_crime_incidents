-- ============================
-- Remove Duplicate Incidents
-- ============================

-- Create a CTE that numbers incidents that are duplicate on distinct id columns
WITH rownum_cte AS (
SELECT ctid,
	ROW_NUMBER() OVER (
	PARTITION BY incident_id,
				 officer_id,
				 suspect_id,
				 victim_id
				 ORDER BY
				 	incident_id
	) AS row_num
FROM crime_incidents
)

-- Remove duplicates from dataset whilst leaving the original in tact
DELETE FROM crime_incidents AS c
USING rownum_cte AS rn
WHERE rn.row_num > 1 
  AND rn.ctid = c.ctid;

-- =========================
-- Clean Date
-- =========================

-- Remove extra spaces from datetime input
WITH cleaned AS (
    SELECT
        incident_datetime,
        TRIM(incident_datetime) AS idt
    FROM crime_incidents
),

-- Standardize datetime format and set default time to midnight if blank
parsed AS (
    SELECT
                CASE
            -- Format: MM/DD/YY HH:MI
            WHEN idt ~ '^\d{1,2}/\d{1,2}/\d{2} \d{1,2}:\d{2}$'
                THEN TO_TIMESTAMP(idt, 'MM/DD/YY HH24:MI')

            -- Format: MM/DD/YY (no time -> default midnight)
            WHEN idt ~ '^\d{1,2}/\d{1,2}/\d{2}$'
                THEN TO_TIMESTAMP(idt || ' 00:00', 'MM/DD/YY HH24:MI')

            -- Format: DD-MM-YYYY (no time -> default midnight)
            WHEN idt ~ '^\d{2}-\d{2}-\d{4}$'
                THEN TO_TIMESTAMP(idt || ' 00:00', 'DD-MM-YYYY HH24:MI')

            ELSE NULL
        END AS clean_timestamp

    FROM cleaned
)

SELECT *
FROM parsed;

-- =========================
-- Property Loss
-- =========================
/*
The property loss column contains values with multiple decimal places. Before the value can be cast to a numeric data type,
the values must be standardized by maintaining the initial decimal point, but removing subsequent points
*/
WITH normal_property_loss AS (
SELECT
  ROUND(
    REPLACE(
      REGEXP_REPLACE(
        REGEXP_REPLACE(property_loss_usd, '\.', '#'), -- Hide first decimal point by temporarily replacing it with "#"
        '\.', '', 'g'                           	  -- Strip remaining decimal point
      ),
      '#', '.'                                  	  -- Restore first dot
    )::numeric,                                 	  -- Cast value to numeric data type
    2                                           	  -- Round final value to 2 decimal places
  ) AS n_property_loss_usd
FROM crime_incidents
)
-- Standardize inputs by removing negative values (property loss cannot be negative )
SELECT CASE
		WHEN n_property_loss_usd < 0 THEN ROUND((n_property_loss_usd / -1), 2)
		ELSE n_property_loss_usd
	END AS std_property_loss_usd
FROM normal_property_loss;

-- =========================
-- Ages
-- =========================

SELECT
	CASE
		WHEN suspect_age < 0 THEN (suspect_age / -1) -- Corrects negative age inputs
		WHEN suspect_age > 110 THEN CAST(LEFT(suspect_age::text, LENGTH(suspect_age::text) - 1) AS INTEGER) -- Assumes that age values over 110 received an extra digit as a typo
		ELSE suspect_age
	END AS std_suspect_age
FROM crime_incidents;

--

SELECT
	CASE
		WHEN victim_age < 0 THEN (victim_age / -1) -- Corrects negative age inputs
		WHEN victim_age > 110 THEN CAST(LEFT(victim_age::text, LENGTH(victim_age::text) - 1) AS INTEGER) -- Assumes that age values over 110 received an extra digit as a typo
		ELSE victim_age
	END AS std_victim_age
FROM crime_incidents;

-- =========================
-- Number of Arrests
-- =========================

SELECT
	CASE
		WHEN num_arrests < 0 THEN (num_arrests / -1) -- Corrects negative inputs
		WHEN num_arrests IS NULL THEN 0 -- Sets default NULL to 0 (assumes no arrests were made)
		ELSE num_arrests
	END AS std_num_arrests
FROM crime_incidents;

